# Build from workspace root: docker build -f crates/jwtlet-server/Dockerfile.test -t jwtlet:test .

# --- Chef base ---
FROM rust:bookworm AS chef

RUN cargo install cargo-chef

RUN apt-get update && apt-get install -y cmake && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# --- Planner: analyze dependencies ---
FROM chef AS planner

COPY . .

RUN cargo chef prepare --recipe-path recipe.json

# --- Builder: build deps (cached) then app ---
FROM chef AS builder

COPY --from=planner /build/recipe.json recipe.json

RUN cargo chef cook --release --recipe-path recipe.json

ARG CACHE_INVALIDATE=unknown

RUN echo "cache-invalidate=$CACHE_INVALIDATE"

COPY . .

RUN cargo build --release --bin jwtlet-server

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    curl \
    wget \
    libssl3 \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/target/release/jwtlet-server /

ENV RUST_LOG=info

EXPOSE 8080 8081

CMD ["/jwtlet-server"]
